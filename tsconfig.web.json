{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "composite": true,
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./out",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./renderer/src/*"]
    }
  },
  "include": [
    "renderer/src/**/*.ts",
    "renderer/src/**/*.tsx",
    "renderer/src/**/*.json"
  ]
}
